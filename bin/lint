#!/bin/bash -ex
# Developer static checks (not used at train/deploy time).
# CI: .github/workflows/test.yaml runs this after uv sync --dev.
#
#   ./bin/lint

BLACK_ARG=""
RUFF_ARG="check --fix"

# Format (black chosen for type-annotation handling)
uv run black -l 120 $BLACK_ARG flash_rl train.py

# Lint + autofix
uv run ruff $RUFF_ARG flash_rl

# Type check
uv run mypy flash_rl train.py
